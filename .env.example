# HIVE.AI — Variables d'environnement
# Copier vers .env et remplir les valeurs
# Swarmly SAS · 2026

# Serveur
HIVE_PORT=5000
HIVE_HOST=0.0.0.0
HIVE_DEBUG=false
HIVE_WORKERS=2

# Domaine
HIVE_DOMAIN=hive-ai.tech

# Securite — generer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGER-MOI-generer-un-secret-avec-la-commande-ci-dessus

# API Anthropic (voix de Nu)
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE-CLE-ICI

# Bureau de Commandement — acces Capitaine uniquement
# Si absent, un token est genere au demarrage et affiche dans les logs
HIVE_BUREAU_TOKEN=CHANGER-MOI-token-secret-capitaine
# IPs supplementaires autorisees (separees par virgule)
# HIVE_BUREAU_IPS=192.168.1.100,10.0.0.5
